{
  "name": "b2b-linkedin-content-signal-lab",
  "version": "0.1.0",
  "private": true,
  "description": "High-signal research on organic LinkedIn strategy for B2B SaaS.",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "validate": "tsx scripts/validate-research.ts",
    "validate:strict": "tsx scripts/validate-research.ts --strict",
    "collect:transcripts": "tsx scripts/collect-transcripts.ts",
    "check": "npm run typecheck && npm run validate && npm run render:linkedin-posts:dry && npm run collect:transcripts:dry",
    "collect:transcripts:dry": "tsx scripts/collect-transcripts.ts --dry-run",
    "render:linkedin-posts": "tsx scripts/render-linkedin-posts.ts",
    "render:linkedin-posts:dry": "tsx scripts/render-linkedin-posts.ts --dry-run"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
